[Unit]
Description=SimuScale Backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Desktop/vcc/backend
ExecStart=/root/Desktop/vcc/backend/venv/bin/uvicorn api.server:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
